{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Diatom chrome capabilities — applies ONLY to the diatom:// origin (index.html and ui/*.html). Third-party web content loaded in the WebView cannot call any of these IPC commands.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:allow-print",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-remove",
    "fs:allow-exists",
    "fs:allow-app-read",
    "fs:allow-app-write",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "notification:allow-notify",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "http:allow-fetch",
    "http:allow-fetch-cancel",
    "http:allow-fetch-read-body",
    "http:allow-fetch-send",
    "store:allow-get",
    "store:allow-set",
    "store:allow-delete",
    "store:allow-clear",
    "store:allow-reset",
    "store:allow-keys",
    "store:allow-values",
    "store:allow-entries",
    "store:allow-length",
    "store:allow-load",
    "store:allow-save"
  ]
}
